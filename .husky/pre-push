#
# Pre-push gate: refuse to publish anything the team can't build cleanly.
# Covers prettier formatting, gofmt, go vet, and frontend type-check.
# To skip in an emergency: git push --no-verify
#

set -e

echo "▸ prettier --check"
npm run --silent format:check

echo "▸ gofmt -l"
npm run --silent go:fmt:check

echo "▸ go vet"
npm run --silent go:vet

echo "▸ tsc --noEmit"
npm run --silent frontend:type-check

echo "✓ pre-push checks passed"
